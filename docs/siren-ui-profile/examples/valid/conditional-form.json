{
  "class": ["deployment", "form"],
  "properties": {"environment": "staging"},
  "entities": [
    {
      "class": ["modwire-ui-profile"],
      "rel": ["https://raw.githubusercontent.com/modwire/modwire-siren/main/docs/siren-ui-profile/README.md#profile-entity"],
      "properties": {
        "profile": "https://raw.githubusercontent.com/modwire/modwire-siren/main/docs/siren-ui-profile/README.md",
        "presentation": {"role": "form", "label": "Create deployment"},
        "properties": {"environment": {"label": "Current environment", "format": "status"}},
        "actions": {
          "deploy": {
            "intent": "primary",
            "placement": "entity",
            "fields": {
              "strategy": {"widget": "select", "label": "Strategy", "choices": {"kind": "inline"}, "order": 10},
              "canary_percent": {
                "widget": "number",
                "label": "Canary percentage",
                "order": 20,
                "visibleWhen": {"path": "fields/strategy", "operator": "equals", "value": "canary"}
              },
              "reason": {
                "widget": "textarea",
                "label": "Production change reason",
                "order": 30,
                "enabledWhen": {"path": "fields/environment", "operator": "equals", "value": "production"}
              }
            },
            "result": {"mode": "monitor", "relations": ["progress"], "optimistic": false}
          }
        }
      },
      "entities": [],
      "actions": [],
      "links": []
    }
  ],
  "actions": [
    {
      "name": "deploy",
      "title": "Deploy",
      "method": "POST",
      "href": "https://api.example.test/deployments",
      "type": "application/json",
      "fields": [
        {"name": "environment", "type": "hidden", "value": "staging"},
        {"name": "strategy", "type": "radio", "value": [
          {"value": "rolling", "title": "Rolling", "selected": true},
          {"value": "canary", "title": "Canary"}
        ]},
        {"name": "canary_percent", "type": "number"},
        {"name": "reason", "type": "text"}
      ]
    }
  ],
  "links": [
    {"rel": ["self"], "href": "https://api.example.test/deployments/new"},
    {"rel": ["profile"], "href": "https://raw.githubusercontent.com/modwire/modwire-siren/main/docs/siren-ui-profile/README.md"}
  ]
}
